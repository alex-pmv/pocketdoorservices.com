---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const { title, description = "Pocket Door Services — expert pocket door installation, repair & maintenance in Orlando, Miami & Fort Myers, FL. 24/7 emergency service. Call (954) 727-5410.", keywords = "pocket door services, pocket door installation, pocket door repair, pocket door maintenance, Orlando, Miami, Fort Myers, FL, sliding pocket doors, commercial pocket doors" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Build breadcrumb items from URL
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: "Home", url: "https://pocketdoorservices.com/" }
];
let cumulativePath = "";
for (const segment of pathSegments) {
  cumulativePath += `/${segment}`;
  const name = segment.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  breadcrumbItems.push({ name, url: `https://pocketdoorservices.com${cumulativePath}` });
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="Mip6-fpzUisHx5viJ5yupG85LJAL395t9cgjOyl6e2k" />
    <link rel="icon" type="image/png" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="alternate" hreflang="en" href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Pocket Door Services" />
    <meta property="og:image" content={new URL('/images/logo.png', Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/logo.png', Astro.site).href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.google.com" />
    <link rel="preconnect" href="https://www.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="dns-prefetch" href="https://api.web3forms.com" />
    <link rel="dns-prefetch" href="https://hooks.zapier.com" />
    <title>{title}</title>

    <!-- Universal Form Handler: Web3Forms + Zapier + UTM + reCaptcha v3 + Tracking -->
    <script is:inline>
      (function() {
        // Inject honeypot field into all forms (bots fill it, humans don't see it)
        document.addEventListener('DOMContentLoaded', function() {
          document.querySelectorAll('[data-form-name]').forEach(function(form) {
            var hp = document.createElement('input');
            hp.type = 'checkbox'; hp.name = 'botcheck'; hp.style.display = 'none';
            form.appendChild(hp);
          });
        });

        function getUtmParams() {
          var params = new URLSearchParams(window.location.search);
          var keys = ['gclid','utm_source','utm_medium','utm_campaign','utm_term','utm_content','fbclid'];
          var result = {};
          keys.forEach(function(k) { if (params.get(k)) result[k] = params.get(k); });
          return result;
        }

        function submitForm(form, formData, formName, btn, origText) {
          var utms = getUtmParams();
          var pageUrl = window.location.href;

          // Build payload for Zapier
          var payload = { form_name: formName, 'Page URL': pageUrl };
          formData.forEach(function(val, key) {
            if (key !== 'access_key' && key !== 'subject' && key !== 'recaptcha_response' && key !== 'botcheck') payload[key] = val;
          });
          Object.assign(payload, utms);

          // Add UTM fields to Web3Forms submission too
          Object.keys(utms).forEach(function(k) { formData.append(k, utms[k]); });
          formData.append('page_url', pageUrl);
          formData.append('form_name', formName);

          // Submit to Web3Forms + Zapier in parallel
          var web3 = fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
          fetch('https://hooks.zapier.com/hooks/catch/15056432/3tal1j3/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams(payload).toString(),
            mode: 'no-cors'
          }).catch(function() {});

          web3.then(function(r) { return r.json(); }).then(function(data) {
            if (data.success) {
              if (typeof fbq === 'function') fbq('track', 'Lead');
              if (window.dataLayer) window.dataLayer.push({ event: 'form_submission', form_name: formName });
              window.location.href = '/thank-you';
            } else {
              if (btn) { btn.innerHTML = 'Error — Try Again'; btn.disabled = false; }
              setTimeout(function() { if (btn) btn.innerHTML = origText; }, 3000);
            }
          }).catch(function() {
            if (btn) { btn.innerHTML = 'Error — Try Again'; btn.disabled = false; }
            setTimeout(function() { if (btn) btn.innerHTML = origText; }, 3000);
          });
        }

        // Clear custom validity when user edits phone field
        document.addEventListener('input', function(e) {
          if (e.target && e.target.name === 'Phone') {
            e.target.setCustomValidity('');
          }
        });

        document.addEventListener('submit', function(e) {
          var form = e.target;
          if (!form.matches || !form.matches('[data-form-name]')) return;
          e.preventDefault();

          // Phone validation - 7-15 digits
          var phoneInput = form.querySelector('input[name="Phone"]');
          if (phoneInput) {
            var digits = phoneInput.value.replace(/\D/g, '');
            if (digits.length < 7 || digits.length > 15) {
              phoneInput.setCustomValidity('Please enter a valid phone number (e.g. 954-727-5410)');
              phoneInput.reportValidity();
              return;
            }
            phoneInput.setCustomValidity('');
          }

          var btn = form.querySelector('button[type="submit"]');
          var origText = btn ? btn.innerHTML : '';
          if (btn) { btn.innerHTML = 'Sending...'; btn.disabled = true; }

          var formData = new FormData(form);
          var formName = form.getAttribute('data-form-name');

          // Get fresh reCaptcha v3 token
          if (typeof grecaptcha !== 'undefined') {
            grecaptcha.ready(function() {
              grecaptcha.execute('6Lfr26EsAAAAALbvO6AH8o0hH-msBboNjMAtKweo', { action: 'contact' })
                .then(function(token) {
                  formData.append('recaptcha_response', token);
                  submitForm(form, formData, formName, btn, origText);
                });
            });
          } else {
            submitForm(form, formData, formName, btn, origText);
          }
        });
      })();
    </script>
    <script async src="https://www.google.com/recaptcha/api.js?render=6Lfr26EsAAAAALbvO6AH8o0hH-msBboNjMAtKweo"></script>
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VG1H9Y4MP0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VG1H9Y4MP0');
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Pocket Door Services",
      "description": "Expert pocket door installation, repair, and maintenance services in Orlando, Miami, and Fort Myers, FL. 24/7 emergency service available.",
      "url": "https://pocketdoorservices.com",
      "telephone": "+1-954-727-5410",
      "image": "https://pocketdoorservices.com/images/logo.png",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Orlando",
        "addressRegion": "FL",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "City", "name": "Orlando" },
        { "@type": "City", "name": "Miami" },
        { "@type": "City", "name": "Fort Myers" }
      ],
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      },
      "sameAs": [
        "https://maps.google.com/maps?cid=14237320329652946561",
        "https://maps.google.com/maps?cid=1347897679910126207"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbItems.map((item, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "name": item.name,
        "item": item.url
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Pocket Door Services",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Pocket Door Services",
        "url": "https://pocketdoorservices.com"
      },
      "areaServed": [
        { "@type": "City", "name": "Orlando" },
        { "@type": "City", "name": "Miami" },
        { "@type": "City", "name": "Fort Myers" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Pocket Door Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pocket Door Installation" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pocket Door Repair" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Door Lock Services" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Hinge Repair & Replacement" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Lock Repair" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roller Replacement & Frame Repair" } }
        ]
      }
    })} />
  </head>
  <body class="font-body text-gray-800 antialiased">
    <!-- Phone auto-format XXX-XXX-XXXX on all forms -->
    <script is:inline>
      function initPhoneFormat() {
        document.querySelectorAll('input[type="tel"]').forEach(function(input) {
          if (input.dataset.formatted) return;
          input.dataset.formatted = 'true';
          input.addEventListener('input', function() {
            var pos = this.selectionStart;
            var val = this.value.replace(/\D/g, '').substring(0, 10);
            if (val.length >= 7) this.value = val.slice(0,3) + '-' + val.slice(3,6) + '-' + val.slice(6);
            else if (val.length >= 4) this.value = val.slice(0,3) + '-' + val.slice(3);
            else this.value = val;
          });
        });
      }
      document.addEventListener('DOMContentLoaded', initPhoneFormat);
      document.addEventListener('astro:page-load', initPhoneFormat);
    </script>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
