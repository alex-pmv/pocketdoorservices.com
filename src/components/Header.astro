---
const navItems = [
  { name: "Home", href: "/" },
  { name: "About Us", href: "/about-us" },
  { name: "Blog", href: "/blog" },
  { name: "Contact", href: "/contact" },
];
const serviceDropdown = [
  { name: "Roller Replacement & Frame Repair", href: "/service/roller-replacement-and-frame-repair" },
  { name: "Lock Repair", href: "/service/lock-repair" },
  { name: "Hinge Repair/Replacement", href: "/service/hinge-repair-replacement" },
  { name: "Commercial Door Installation", href: "/service/commercial-door-installation" },
  { name: "Commercial Door Repair", href: "/service/commercial-door-repair" },
  { name: "Commercial Door Lock Services", href: "/service/commercial-door-lock-services" },
];
const locationDropdown = [
  { name: "Orlando", href: "/location/pocket-door-services-orlando" },
  { name: "Fort Myers", href: "/location/fort-myers" },
  { name: "Miami", href: "/location/pocket-door-services-miami" },
];
---

<div class="bg-primary text-white text-sm py-2">
  <div class="max-w-7xl mx-auto px-4 flex justify-end items-center gap-4 whitespace-nowrap">
    <span class="hidden sm:inline">Serving Orlando, Miami & Fort Myers, FL</span>
    <span class="sm:hidden">Orlando · Miami · Fort Myers</span>
    <a href="tel:9547275410" class="hover:underline font-semibold" aria-label="Call Pocket Door Services">(954) 727-5410</a>
  </div>
</div>

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-24">
    <a href="/" class="flex-shrink-0 flex items-center gap-2">
      <img src="/images/logo copy.png" alt="Pocket Door Services - Expert Installation & Repair in Orlando, Miami & Fort Myers" class="h-20 w-auto" />
      <div class="flex flex-col justify-center leading-tight" style="color: #114379;">
        <span class="font-heading text-sm sm:text-xl tracking-wide leading-none">POCKET &</span>
        <span class="font-heading text-sm sm:text-xl tracking-wide leading-none">COMMERCIAL</span>
        <span class="font-heading text-sm sm:text-xl tracking-wide leading-none">DOOR SERVICES</span>
      </div>
    </a>
    <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
      <a href="/" class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2">HOME</a>
      <div class="relative group">
        <button class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2 inline-flex items-center gap-1">
          SERVICES
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 min-w-[280px]">
            {serviceDropdown.map((s) => (
              <a href={s.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent transition-colors">{s.name}</a>
            ))}
          </div>
        </div>
      </div>
      <div class="relative group">
        <button class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2 inline-flex items-center gap-1">
          LOCATIONS
          <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="bg-white rounded-lg shadow-xl border border-gray-100 py-2 min-w-[200px]">
            {locationDropdown.map((l) => (
              <a href={l.href} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-accent transition-colors">{l.name}</a>
            ))}
          </div>
        </div>
      </div>
      <a href="/about-us" class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2">ABOUT US</a>
      <a href="/blog" class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2">BLOG</a>
      <a href="/contact" class="font-heading text-lg tracking-wide text-primary hover:text-accent py-2">CONTACT</a>
    </nav>
    <a href="tel:9547275410" class="hidden lg:inline-flex bg-accent text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-blue-700 transition-colors" aria-label="Call now for a free estimate">CALL NOW</a>
    <div class="lg:hidden flex items-center gap-2">
      <a href="tel:9547275410" class="bg-accent text-white font-heading text-sm tracking-wide px-4 py-2 rounded hover:bg-blue-700 transition-colors" aria-label="Call now">CALL NOW</a>
      <button id="mobile-menu-btn" class="p-2" aria-label="Open navigation menu">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 max-h-[calc(100vh-6rem)] overflow-y-auto">
    <div class="px-4 py-4 space-y-3">
      <a href="/" class="block font-heading text-lg tracking-wide text-primary py-2">HOME</a>
      <div>
        <p class="font-heading text-lg tracking-wide text-primary py-2">SERVICES</p>
        <div class="pl-4 space-y-1">
          {serviceDropdown.map((s) => (
            <a href={s.href} class="block text-sm text-gray-600 py-1 hover:text-accent">{s.name}</a>
          ))}
        </div>
      </div>
      <div>
        <p class="font-heading text-lg tracking-wide text-primary py-2">LOCATIONS</p>
        <div class="pl-4 space-y-1">
          {locationDropdown.map((l) => (
            <a href={l.href} class="block text-sm text-gray-600 py-1 hover:text-accent">{l.name}</a>
          ))}
        </div>
      </div>
      <a href="/about-us" class="block font-heading text-lg tracking-wide text-primary py-2">ABOUT US</a>
      <a href="/blog" class="block font-heading text-lg tracking-wide text-primary py-2">BLOG</a>
      <a href="/contact" class="block font-heading text-lg tracking-wide text-primary py-2">CONTACT</a>
      <a href="tel:9547275410" class="block bg-accent text-white font-heading text-lg tracking-wide px-6 py-3 rounded text-center mt-4">CALL NOW</a>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
