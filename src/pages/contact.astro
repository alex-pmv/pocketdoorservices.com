---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us | Pocket Door Services — Free Estimates in Orlando, Miami & Fort Myers"
  description="Get a free pocket door estimate from Florida's pocket door specialists. Installation, repair & emergency service across Orlando, Miami & Fort Myers. Call (954) 727-5410 — open 24/7."
>
  <section class="relative bg-primary text-white py-20 md:py-24 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/hero.png')" role="img" aria-label="Pocket door services contact"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/75 to-primary/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-6xl tracking-wide mb-4">Get in Touch — We're Here to Help</h1>
      <p class="text-accent font-heading text-xl tracking-wide mt-4">Serving Orlando, Miami & Fort Myers, FL</p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Contact Our Team Directly</h2>
        <p class="text-gray-600 leading-relaxed mb-4">Have a question about your pocket door? Need an emergency repair? Want a quote for a new installation? We're ready to help. Call us, fill out the form, or reach out to the location nearest you.</p>
        <div class="space-y-3">
          <a href="tel:9547275410" class="flex items-center gap-3 px-5 py-3 bg-primary text-white rounded-lg hover:bg-primary/80 transition-colors font-semibold" aria-label="Call Pocket Door Services">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Miami: (954) 727-5410
          </a>
          <a href="tel:4075578893" class="flex items-center gap-3 px-5 py-3 bg-primary text-white rounded-lg hover:bg-primary/80 transition-colors font-semibold" aria-label="Call Pocket Door Services Orlando">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Orlando: (407) 557-8893
          </a>
          <a href="tel:2392430906" class="flex items-center gap-3 px-5 py-3 bg-primary text-white rounded-lg hover:bg-primary/80 transition-colors font-semibold" aria-label="Call Pocket Door Services Fort Myers">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Fort Myers: (239) 243-0906
          </a>
          <p class="flex items-center gap-3 text-primary font-heading text-2xl tracking-wide pt-3">
            <svg class="w-6 h-6 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Open 24 Hours
          </p>
        </div>
      </div>
      <form class="space-y-4 bg-gray-light p-8 rounded-lg" data-form-name="Contact Page Form">
        <input type="hidden" name="access_key" value="9393b426-71fc-49e0-9346-eebb28bd6b72" />
        <input type="hidden" name="subject" value="New Contact Form - Pocket Door Services" />
        <input type="hidden" name="from_name" value="Pocket Door Services Website" />
        <input type="text" name="Name" placeholder="Name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="tel" name="Phone" placeholder="Phone" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="email" name="Email" placeholder="Email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <textarea name="Message" placeholder="How can we help?" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent resize-vertical"></textarea>
        <button type="submit" class="w-full bg-accent text-white font-heading text-xl tracking-wide py-4 rounded-lg hover:bg-blue-700 transition-colors">SEND</button>
      </form>
    </div>
  </section>

  <!-- Intro text -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-gray-600 leading-relaxed">
        Whether you have a pocket door that's stuck, need a quote for a new installation, or just want advice on whether a pocket door is right for your space — reach out. Our team responds to most inquiries within a few hours during business days. For emergencies, call us directly — we're available 24/7.
      </p>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Why Florida Homeowners & Businesses Choose Us</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
        {[
          { name: "Fast & Reliable", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
          { name: "Upfront Written Quotes", icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "5-Star Rated", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" },
          { name: "24/7 Emergency Service", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Pocket Door Specialists", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
          { name: "All Payment Methods", icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" },
        ].map((f) => (
          <div class="text-center p-6 bg-gray-light rounded-lg shadow-sm">
            <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon} /></svg>
            </div>
            <h3 class="font-heading text-lg tracking-wide text-primary">{f.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
