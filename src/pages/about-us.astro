---
import Layout from '../layouts/Layout.astro';
import services from '../data/services.json';
---

<Layout
  title="About Pocket Door Services | Expert Technicians in FL"
  description="About Pocket Door Services — your trusted pocket door experts in Orlando, Miami & Fort Myers. Expert installation, repair & maintenance. Call (954) 727-5410."
>
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">About Pocket Door Services</h1>
    </div>
  </section>

  <!-- About -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Top Pocket Door Services - Expert Repairs & Installations</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Welcome to Pocket Door Services, your trusted partner for all things related to pocket doors. With years of expertise in the industry, we specialize in the installation, repair, and maintenance of pocket doors, ensuring they operate smoothly and efficiently. Our dedicated team of professionals is committed to providing high-quality workmanship and exceptional customer service.
        </p>
        <a href="/contact" class="inline-flex bg-accent text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-blue-700 transition-colors">GET A FREE ESTIMATE</a>
      </div>
      <div>
        <img src="/images/services/hero.webp" alt="Pocket Door Services" class="rounded-lg shadow-lg w-full" />
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-4">Why Choose Us</h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-10">Our team of skilled technicians brings years of experience and a commitment to quality workmanship to every project.</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
        {[
          { name: "Fast & Reliable", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
          { name: "Transparent Pricing", icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Customer Satisfaction", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" },
          { name: "Emergency 24/7", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Quality Tools", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
          { name: "Expert Technicians", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
        ].map((f) => (
          <div class="text-center p-6 bg-white rounded-lg shadow-sm">
            <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon} /></svg>
            </div>
            <h3 class="font-heading text-lg tracking-wide text-primary">{f.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Emergency -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Pocket Door Emergency Services</h2>
      <p class="text-gray-300 leading-relaxed mb-8">
        At Pocket Door Services, we understand that issues can arise unexpectedly, which is why we offer reliable pocket door emergency services to address urgent repairs and get your doors back on track quickly.
      </p>
      <a href="tel:9547275410" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call Now 954-727-5410</a>
    </div>
  </section>

  <!-- Affordable + Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
      <div>
        <img src="/images/services/about.webp" alt="Affordable Pocket Door Services" class="rounded-lg shadow-lg w-full" />
      </div>
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Most Affordable Pocket Door Services</h2>
        <p class="text-gray-600 leading-relaxed">As the most affordable pocket door services provider, we ensure that you receive high-quality workmanship without breaking the bank.</p>
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <div class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={s.image} alt={s.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{s.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Estimate -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Get Your Free Estimate!</h2>
        <p class="text-gray-600 leading-relaxed">Transform your space with the convenience and elegance of pocket doors. Contact us for a consultation.</p>
      </div>
      <form class="space-y-4 bg-white p-8 rounded-lg shadow-sm" action="#" method="POST">
        <input type="text" name="name" placeholder="Name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <textarea name="message" placeholder="Message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent resize-vertical"></textarea>
        <button type="submit" class="w-full bg-accent text-white font-heading text-xl tracking-wide py-4 rounded-lg hover:bg-blue-700 transition-colors">SEND</button>
      </form>
    </div>
  </section>
</Layout>
