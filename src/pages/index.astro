---
import Layout from '../layouts/Layout.astro';
import services from '../data/services.json';
import GlassmorphismHero from '../components/ui/glassmorphism-trust-hero.astro';
---

<Layout
  title="Pocket Door Services Florida | Expert Installation, Repair & Replacement in Orlando, Miami & Fort Myers"
  description="Florida's trusted pocket door specialists — professional installation, repair & replacement in Orlando, Miami & Fort Myers. No wall damage guaranteed. 24/7 emergency service. Free estimates. Call (954) 727-5410."
>

  <!-- Hero -->
  <GlassmorphismHero />

  <!-- Top Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Why Pocket Doors — And Why We're the Team to Call</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          Pocket doors save up to 15 square feet of usable floor space per opening — space that a swinging door wastes every time it arcs open. For bathrooms, closets, offices, and tight hallways, that recovered space changes how a room feels and functions. Whether you're renovating a home or outfitting a commercial space, pocket doors deliver a cleaner look and better flow.
        </p>
        <p class="text-gray-600 leading-relaxed mb-6">
          The difference between a pocket door that glides effortlessly and one that rattles, sticks, or derails comes down to the installer. Most contractors treat pocket doors like an afterthought — wrong track gauge, cheap rollers, no alignment check after the drywall goes up. We do things differently. Every installation includes precision-leveled framing, contractor-grade hardware matched to your door weight, and a post-drywall adjustment that most companies skip entirely. That final step is why our doors still glide smoothly years later.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/about-us" class="inline-flex bg-primary text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-dark transition-colors">MEET OUR TEAM</a>
          <a href="/blog" class="inline-flex border-2 border-primary text-primary font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-primary hover:text-white transition-colors">READ OUR BLOG</a>
        </div>
      </div>
      <div>
        <img src="/images/night work.webp" alt="Pocket door installation by expert technician in Orlando" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-4">What Sets Us Apart From General Contractors</h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-10">Most door companies juggle dozens of services. We built our business around pocket doors, sliding doors, and commercial door systems — and that expertise shows in every detail of how we work.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { name: "Fast & Reliable", desc: "We show up on time, diagnose fast, and fix it right — most jobs completed in a single visit", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
          { name: "Upfront Pricing", desc: "You get a written quote before we start — no surprise charges, ever", icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "5-Star Rated", desc: "Hundreds of verified reviews from homeowners and businesses across Florida", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" },
          { name: "Post-Install Adjustment", desc: "We return after drywall to re-level and fine-tune — others don't", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
          { name: "24/7 Emergency Service", desc: "Locked out or stuck? We respond day and night, weekends included", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Hardware Matched to Weight", desc: "We size rollers and tracks to your exact door — not one-size-fits-all parts", icon: "M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" },
          { name: "Door Specialists", desc: "Pocket doors, sliding doors, and commercial doors — it's what we know best", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
          { name: "All Payment Methods", desc: "Cash, check, and all major credit cards accepted on-site", icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" },
        ].map((f) => (
          <div class="text-center p-6 bg-white rounded-lg shadow-sm">
            <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon} /></svg>
            </div>
            <h3 class="font-heading text-lg tracking-wide text-primary">{f.name}</h3>
            <p class="text-gray-500 text-sm mt-1">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Emergency -->
  <section class="relative py-20 text-white text-center overflow-hidden">
    <div class="absolute inset-0 bg-cover" style="background-image: url('/images/beach.webp'); background-position: center 35%;"></div>
    <div class="absolute inset-0 bg-primary/90"></div>
    <div class="relative max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Pocket Door Emergency? We're Already on the Way.</h2>
      <p class="text-gray-300 leading-relaxed mb-4">
        A pocket door that won't close means a bathroom you can't use, an office you can't secure, or a storefront that can't lock up for the night. We get it — these aren't problems that can wait until Monday.
      </p>
      <p class="text-gray-300 leading-relaxed mb-8">
        Our emergency pocket door repair team responds 24/7, 365 days a year across Orlando, Miami, and Fort Myers. We arrive with a fully stocked truck — <a href="/service/roller-replacement-and-frame-repair" class="text-accent hover:underline">rollers</a>, tracks, <a href="/service/lock-repair" class="text-accent hover:underline">locks</a>, <a href="/service/hinge-repair-replacement" class="text-accent hover:underline">hinges</a>, and hardware — so most emergency repairs are completed in a single visit. No return trips, no waiting on parts.
      </p>
      <a href="tel:9547275410" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call Now (954) 727-5410</a>
    </div>
  </section>

  <!-- Affordable -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <img src="/images/old track demo.webp" alt="Old pocket door track showing wear and damage" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Honest Pricing, No Shortcuts</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          We've seen what happens when homeowners hire the cheapest bid — undersized rollers that wear out in months, tracks that weren't leveled, and drywall patches that crack because the framing wasn't reinforced. Cutting corners on a pocket door installation always costs more in the long run.
        </p>
        <p class="text-gray-600 leading-relaxed mb-4">
          Our pricing is competitive because we're efficient — not because we skip steps. You get a detailed written estimate before any work begins, and we walk you through exactly what we're doing and why. No vague line items, no surprise upcharges when we're halfway through the job.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Whether it's a single <a href="/service/lock-repair" class="text-accent hover:underline">pocket door lock repair</a> or a multi-door <a href="/service/commercial-door-installation" class="text-accent hover:underline">commercial installation</a>, you'll know the full cost upfront. That's how we've maintained a 97% client satisfaction rate across 500+ projects — and it's why most of our work comes from referrals and repeat customers.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Serving <a href="/location/pocket-door-services-orlando" class="text-accent hover:underline">Orlando</a>, <a href="/location/pocket-door-services-miami" class="text-accent hover:underline">Miami</a>, and <a href="/location/fort-myers" class="text-accent hover:underline">Fort Myers</a>. Read our <a href="/blog/pocket-door-installation-cost-florida" class="text-accent hover:underline">guide to pocket door installation costs</a> to learn what to expect.
        </p>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-gray-light" id="services">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-4">Pocket Door Services for Every Situation</h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-10">From a single stuck pocket door in your bathroom to a full commercial build-out with dozens of openings — we handle residential and commercial pocket door projects of every size. Each service below is backed by our expertise and our commitment to getting it right the first time.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/service/${s.slug}`} class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-border/30 block">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={s.image} alt={`${s.name} service in Orlando, Miami & Fort Myers`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{s.description}</p>
              <span class="inline-flex items-center gap-1 text-accent font-heading text-sm tracking-wide group-hover:gap-2 transition-all duration-300">
                LEARN MORE
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- From Our Blog -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-4">From Our Blog</h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-10">Expert guides to help you understand your pocket door issues and make informed decisions.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/blog/signs-your-pocket-door-rollers-need-replacing" class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30">
          <div class="aspect-[16/9] overflow-hidden">
            <img src="/images/old tracks.webp" alt="Worn pocket door rollers and tracks" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-5">
            <p class="text-accent text-sm font-medium mb-1">March 24, 2026</p>
            <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">5 Signs Your Pocket Door Rollers Need Replacing</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Learn the warning signs that your pocket door rollers are failing — and why replacing them early saves you money.</p>
          </div>
        </a>
        <a href="/blog/pocket-door-lock-hinge-problems-guide" class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30">
          <div class="aspect-[16/9] overflow-hidden">
            <img src="/images/new lock.webp" alt="Pocket door lock repair" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
          <div class="p-5">
            <p class="text-accent text-sm font-medium mb-1">March 10, 2026</p>
            <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Pocket Door Lock & Hinge Problems: Repair vs Replace</h3>
            <p class="text-gray-600 text-sm leading-relaxed">Not sure whether to repair or replace your pocket door lock or hinge? Here's how to decide.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary text-center mb-4">Rated 5 Stars by Homeowners & Businesses Across Florida</h2>
      <p class="text-center text-gray-600 max-w-3xl mx-auto mb-10">We don't just fix pocket doors — we build lasting relationships with every client. Here's what people are saying after working with our team.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { name: "Rachel G.", location: "Orlando, FL", quote: "We had three pocket doors installed in our master suite renovation. The team leveled everything perfectly and even came back after the drywall was finished to make final adjustments — something our general contractor said he'd never seen a door company do. Every door glides perfectly." },
          { name: "James M.", location: "Miami, FL", quote: "Our bathroom pocket door had been stuck for months. A handyman tried to fix it and made it worse. Pocket Door Services came out the same day, diagnosed a bent track and worn rollers, and had it running like new in under an hour. Should have called them first." },
          { name: "Karen B.", location: "Fort Myers, FL", quote: "We hired them for a 12-door commercial installation in our new medical office. Every door was properly weighted, the privacy locks work flawlessly, and they stayed within the quoted price. The attention to detail was obvious from day one. Already referred them to two other businesses." },
        ].map((t) => (
          <div class="bg-gray-light rounded-lg p-6 shadow-sm border border-gray-border/30">
            <div class="flex items-center gap-1 mb-3">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-600 italic mb-4">"{t.quote}"</p>
            <p class="font-heading text-lg text-primary">{t.name}</p>
            <p class="text-sm text-gray-400">{t.location}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Pocket Door Services",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "reviewCount": "3", "bestRating": "5" },
    "review": [
      { "@type": "Review", "author": { "@type": "Person", "name": "Rachel G." }, "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "We had three pocket doors installed in our master suite renovation. The team leveled everything perfectly and even came back after the drywall was finished to make final adjustments. Every door glides perfectly." },
      { "@type": "Review", "author": { "@type": "Person", "name": "James M." }, "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Our bathroom pocket door had been stuck for months. Pocket Door Services came out the same day, diagnosed a bent track and worn rollers, and had it running like new in under an hour. Should have called them first." },
      { "@type": "Review", "author": { "@type": "Person", "name": "Karen B." }, "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "We hired them for a 12-door commercial installation in our new medical office. Every door was properly weighted, the privacy locks work flawlessly, and they stayed within the quoted price. Already referred them to two other businesses." }
    ]
  })} />

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="group bg-gray-light rounded-lg border border-gray-border/30">
          <summary class="flex items-center justify-between cursor-pointer p-6 font-heading text-lg tracking-wide text-primary">
            How much does pocket door installation cost?
            <svg class="w-5 h-5 text-accent transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">
            Pocket door installation costs in Florida typically range from $500 to $2,500 depending on the door size, materials, and whether it is a new installation or a conversion from an existing door. We offer free estimates — <a href="/contact" class="text-accent hover:underline">contact us</a> or call <a href="tel:9547275410" class="text-accent hover:underline">(954) 727-5410</a> for a personalized quote. Learn more about our <a href="/service/commercial-door-installation" class="text-accent hover:underline">installation services</a>.
          </div>
        </details>
        <details class="group bg-gray-light rounded-lg border border-gray-border/30">
          <summary class="flex items-center justify-between cursor-pointer p-6 font-heading text-lg tracking-wide text-primary">
            Can you convert a regular door to a pocket door?
            <svg class="w-5 h-5 text-accent transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">
            Yes, in most cases a regular swinging door can be converted to a pocket door. The process involves modifying the wall framing to create a pocket cavity for the door to slide into. Our technicians assess the wall structure, plumbing, and electrical to ensure a safe conversion. <a href="/contact" class="text-accent hover:underline">Request a free estimate</a> to find out if your door qualifies.
          </div>
        </details>
        <details class="group bg-gray-light rounded-lg border border-gray-border/30">
          <summary class="flex items-center justify-between cursor-pointer p-6 font-heading text-lg tracking-wide text-primary">
            How long does pocket door installation take?
            <svg class="w-5 h-5 text-accent transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">
            A standard pocket door installation typically takes one to two days. Replacing an existing pocket door or its hardware can often be completed in just a few hours. Timelines vary based on wall modifications and project complexity. Visit our <a href="/service/roller-replacement-and-frame-repair" class="text-accent hover:underline">roller replacement & frame repair</a> page for related services.
          </div>
        </details>
        <details class="group bg-gray-light rounded-lg border border-gray-border/30">
          <summary class="flex items-center justify-between cursor-pointer p-6 font-heading text-lg tracking-wide text-primary">
            Do pocket doors save space?
            <svg class="w-5 h-5 text-accent transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">
            Absolutely. Pocket doors slide into the wall instead of swinging open, freeing up valuable floor and wall space. They are an excellent choice for small rooms, bathrooms, closets, and commercial spaces where maximizing usable area is important. Explore our <a href="/service/commercial-door-installation" class="text-accent hover:underline">commercial door installation</a> options.
          </div>
        </details>
        <details class="group bg-gray-light rounded-lg border border-gray-border/30">
          <summary class="flex items-center justify-between cursor-pointer p-6 font-heading text-lg tracking-wide text-primary">
            Do you serve Orlando, Miami, and Fort Myers?
            <svg class="w-5 h-5 text-accent transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-6 text-gray-600 leading-relaxed">
            Yes, we proudly serve <a href="/location/pocket-door-services-orlando" class="text-accent hover:underline">Orlando</a>, <a href="/location/pocket-door-services-miami" class="text-accent hover:underline">Miami</a>, <a href="/location/fort-myers" class="text-accent hover:underline">Fort Myers</a>, and surrounding areas across Florida. Whether you need residential or commercial pocket door services, our team is ready to help. Call us at <a href="tel:9547275410" class="text-accent hover:underline">(954) 727-5410</a>.
          </div>
        </details>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does pocket door installation cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pocket door installation costs in Florida typically range from $500 to $2,500 depending on the door size, materials, and whether it is a new installation or a conversion from an existing door. Contact Pocket Door Services at (954) 727-5410 for a free estimate."
        }
      },
      {
        "@type": "Question",
        "name": "Can you convert a regular door to a pocket door?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, in most cases a regular swinging door can be converted to a pocket door. The process involves modifying the wall framing to create a pocket cavity for the door to slide into. Our technicians assess the wall structure, plumbing, and electrical to ensure a safe conversion."
        }
      },
      {
        "@type": "Question",
        "name": "How long does pocket door installation take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A standard pocket door installation typically takes one to two days. Replacing an existing pocket door or its hardware can often be completed in just a few hours. Timelines vary based on wall modifications and project complexity."
        }
      },
      {
