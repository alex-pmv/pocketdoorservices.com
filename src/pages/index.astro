---
import Layout from '../layouts/Layout.astro';
import services from '../data/services.json';
---

<Layout
  title="Pocket Door Services Orlando | Installation, Repair & Maintenance"
  description="Pocket Door Services — expert pocket door installation, repair & maintenance in Orlando, Miami & Fort Myers, FL. 24/7 emergency service. Call (954) 727-5410."
>

  <!-- Hero -->
  <section class="relative bg-primary text-white py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/services/hero.webp')" role="img" aria-label="Pocket door installation service in Orlando, FL"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/95 to-primary/70"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Pocket Door Services in Orlando, Miami & Fort Myers</h1>
        <p class="text-xl md:text-2xl font-light mb-4 text-gray-200">Serving Orlando, Miami & Fort Myers, FL</p>
        <p class="text-base md:text-lg text-gray-300 mb-8">
          Expert pocket door installation, repair, and maintenance for residential and commercial spaces. Enhance your property with smooth, efficient pocket door solutions from our skilled technicians.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="tel:9547275410" class="bg-white text-primary font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-gray-100 transition-colors text-center" aria-label="Call Pocket Door Services">
            (954) 727-5410
          </a>
          <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-center">
            FREE ESTIMATE
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 -mt-12">
    <div class="bg-accent rounded-xl shadow-[0_10px_40px_rgba(0,0,0,0.3)] p-8 md:p-10" id="hero-stats">
      <div class="grid grid-cols-3 gap-8 text-center text-white">
        <div>
          <p class="font-heading text-4xl md:text-5xl stat-number" data-target="500" data-suffix="+">0</p>
          <p class="text-sm text-blue-100 mt-2">Projects Completed</p>
        </div>
        <div>
          <p class="font-heading text-4xl md:text-5xl stat-number" data-target="97" data-suffix="%">0</p>
          <p class="text-sm text-blue-100 mt-2">Satisfaction Rate</p>
        </div>
        <div>
          <p class="font-heading text-4xl md:text-5xl stat-number" data-target="10" data-suffix="+">0</p>
          <p class="text-sm text-blue-100 mt-2">Years Experience</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    function animateCounters() {
      const stats = document.querySelectorAll('.stat-number');
      if (!stats.length) return;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.target || '0');
            const suffix = el.dataset.suffix || '';
            const duration = 2000;
            const start = performance.now();
            function update(now: number) {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = Math.floor(eased * target);
              el.textContent = (target >= 1000 ? current.toLocaleString() : current) + suffix;
              if (progress < 1) requestAnimationFrame(update);
            }
            requestAnimationFrame(update);
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.5 });
      stats.forEach((stat) => observer.observe(stat));
    }
    animateCounters();
    document.addEventListener('astro:after-swap', animateCounters);
  </script>

  <!-- Top Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Expert Pocket Door Installation & Repair</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          We specialize in <a href="/contact" class="text-accent hover:underline">installation, repair, and maintenance</a> of pocket doors, ensuring they operate smoothly and efficiently for residential and commercial spaces in Orlando, Miami, and Fort Myers.
        </p>
        <a href="/about-us" class="inline-flex bg-primary text-white font-heading text-lg tracking-wide px-6 py-3 rounded hover:bg-dark transition-colors">LEARN MORE ABOUT US</a>
      </div>
      <div>
        <img src="/images/services/about.webp" alt="Pocket door installation by expert technician in Orlando" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Why Choose Pocket Door Services</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
        {[
          { name: "Fast & Reliable", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
          { name: "Transparent Pricing", icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Customer Satisfaction", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" },
          { name: "Accepts Credit Card", icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" },
          { name: "Emergency 24/7", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
          { name: "Quality Tools", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z" },
          { name: "Expert Technicians", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
        ].map((f) => (
          <div class="text-center p-6 bg-white rounded-lg shadow-sm">
            <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={f.icon} /></svg>
            </div>
            <h3 class="font-heading text-lg tracking-wide text-primary">{f.name}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Emergency -->
  <section class="relative py-20 text-white text-center overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/services/hero.webp')"></div>
    <div class="absolute inset-0 bg-primary/90"></div>
    <div class="relative max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">24/7 Pocket Door Emergency Services</h2>
      <p class="text-gray-300 leading-relaxed mb-8">
        We offer reliable pocket door emergency services to address urgent repairs and get your doors back on track quickly. Our skilled technicians are equipped to handle any pocket door project.
      </p>
      <a href="tel:9547275410" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call Now (954) 727-5410</a>
    </div>
  </section>

  <!-- Affordable -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <img src="/images/services/about.webp" alt="Affordable pocket door repair and installation service" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Most Affordable Pocket Door Services</h2>
        <p class="text-gray-600 leading-relaxed">
          As the most affordable pocket door services provider, we ensure that you receive high-quality workmanship without breaking the bank. Our experienced technicians are equipped to handle all your pocket door needs, from residential to commercial projects.
        </p>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-gray-light" id="services">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Our Pocket Door Services</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/service/${s.slug}`} class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-border/30 block">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={s.image} alt={`${s.name} service in Orlando, Miami & Fort Myers`} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
            </div>
            <div class="p-5">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{s.description}</p>
              <span class="inline-flex items-center gap-1 text-accent font-heading text-sm tracking-wide group-hover:gap-2 transition-all duration-300">
                LEARN MORE
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary text-center mb-10">What Our Clients Say</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { name: "Rachel G.", location: "Orlando, FL", quote: "Pocket Door Services installed sliding pocket doors in our master bedroom. The team was professional, clean, and the doors work beautifully. Highly recommend!" },
          { name: "James M.", location: "Miami, FL", quote: "Our pocket door was stuck and wouldn't slide. They came out the same day and had it running smoothly in under an hour. Great emergency service!" },
          { name: "Karen B.", location: "Fort Myers, FL", quote: "Excellent work on our office pocket door replacement. Fair pricing, expert installation, and they cleaned up perfectly after the job." },
        ].map((t) => (
          <div class="bg-gray-light rounded-lg p-6 shadow-sm border border-gray-border/30">
            <div class="flex items-center gap-1 mb-3">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-600 italic mb-4">"{t.quote}"</p>
            <p class="font-heading text-lg text-primary">{t.name}</p>
            <p class="text-sm text-gray-400">{t.location}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Pocket Door Services",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5", "reviewCount": "3", "bestRating": "5" },
    "review": [
      { "@type": "Review", "author": { "@type": "Person", "name": "Rachel G." }, "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Pocket Door Services installed sliding pocket doors in our master bedroom. The team was professional, clean, and the doors work beautifully. Highly recommend!" },
      { "@type": "Review", "author": { "@type": "Person", "name": "James M." }, "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Our pocket door was stuck and wouldn't slide. They came out the same day and had it running smoothly in under an hour. Great emergency service!" },
      { "@type": "Review", "author": { "@type": "Person", "name": "Karen B." }, "reviewRating": { "@type": "Rating", "ratingValue": "5" }, "reviewBody": "Excellent work on our office pocket door replacement. Fair pricing, expert installation, and they cleaned up perfectly after the job." }
    ]
  })} />

  <!-- Estimate -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Get Your Free Pocket Door Estimate</h2>
        <p class="text-gray-600 leading-relaxed mb-6">Transform your space with the convenience and elegance of pocket doors. <a href="/contact" class="text-accent hover:underline">Contact us</a> for a consultation and discover how our services can enhance your home or business.</p>
        <div class="space-y-3">
          <p class="flex items-center gap-3 text-gray-700">
            <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:9547275410" class="hover:text-accent font-semibold" aria-label="Call Pocket Door Services">(954) 727-5410</a>
          </p>
          <p class="flex items-center gap-3 text-gray-700">
            <svg class="w-5 h-5 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Open 24/7
          </p>
        </div>
      </div>
      <form id="contact-form" class="space-y-4 bg-white p-8 rounded-lg shadow-sm" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="9393b426-71fc-49e0-9346-eebb28bd6b72" />
        <input type="hidden" name="subject" value="New Contact Form - Pocket Door Services" />
        <input type="hidden" name="from_name" value="Pocket Door Services Website" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
        <input type="hidden" name="recaptcha_response" id="recaptchaResponse" />
        <input type="text" name="name" placeholder="Name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
        <textarea name="message" placeholder="Message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent resize-vertical"></textarea>
        <button id="submit-btn" type="submit" class="w-full bg-accent text-white font-heading text-xl tracking-wide py-4 rounded-lg hover:bg-blue-700 transition-colors">SEND</button>
        <div id="form-result" class="text-center text-sm mt-2 hidden"></div>
      </form>
      <script>
        const RECAPTCHA_SITE_KEY = '6LcSWp4sAAAAAPTA9SQgLbfVV5r_mSdchrxDmgnj';
        const script = document.createElement('script');
        script.src = `https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`;
        document.head.appendChild(script);

        const form = document.getElementById('contact-form');
        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = document.getElementById('submit-btn');
          const result = document.getElementById('form-result');
          btn.textContent = 'SENDING...';
          btn.disabled = true;
          try {
            if (window.grecaptcha) {
              const token = await window.grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'submit' });
              document.getElementById('recaptchaResponse').value = token;
            }
            const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) });
            const data = await response.json();
            if (data.success) {
              result.textContent = 'Thank you! Your message has been sent successfully.';
              result.className = 'text-center text-sm mt-2 text-green-600';
              result.classList.remove('hidden');
              form.reset();
            } else {
              result.textContent = 'Something went wrong. Please try again or call us directly.';
              result.className = 'text-center text-sm mt-2 text-red-600';
              result.classList.remove('hidden');
            }
          } catch {
            result.textContent = 'Something went wrong. Please try again or call us directly.';
            result.className = 'text-center text-sm mt-2 text-red-600';
            result.classList.remove('hidden');
          }
          btn.textContent = 'SEND';
          btn.disabled = false;
        });
      </script>
    </div>
  </section>
</Layout>
