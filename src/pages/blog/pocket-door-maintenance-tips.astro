    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-2xl tracking-wide text-primary mb-6">Related Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/blog/pocket-door-installation-cost-florida" class="bg-white rounded-lg p-6 border border-gray-border/30 hover:shadow-lg transition-shadow block">
